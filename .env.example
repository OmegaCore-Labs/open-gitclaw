# GitHub App (preferred) or Personal Access Token fallback
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook security
WEBHOOK_SECRET=super-long-random-secret-64-chars-minimum

# LLM (Ollama local or cloud via LiteLLM)
LITELLM_MODEL=ollama/llama3.2

# Redis (persistent event bus)
REDIS_URL=redis://localhost:6379/0

# Observability (optional)
OTLP_ENDPOINT=http://localhost:4317

# Server
HOST=0.0.0.0
PORT=8000
